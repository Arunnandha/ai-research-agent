# OpenAI
OPENAI_API_KEY=<your_openai_api_key>
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic (optional)
ANTHROPIC_API_KEY=<your_anthropic_api_key>

# Pinecone
PINECONE_API_KEY=<your_pinecone_api_key>

# Product Hunt
PRODUCT_HUNT_ACCESS_TOKEN=<your_product_hunt_token>
PRODUCT_HUNT_API_URL=https://api.producthunt.com/v2/api/graphql

# RSS Feeds (comma-separated)
RSS_FEED_URLS=https://www.artificialintelligence-news.com/feed/,https://openai.com/news/rss.xml,https://deepmind.google/blog/rss.xml

# Server
PORT=3001

# Scheduler
CRON_SCHEDULE=30 8 * * *
